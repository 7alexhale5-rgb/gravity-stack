{
    "themeName": "Industrial Technical",
    "colors": {
        "background": {
            "app": "#0C0C0C",
            "surface": "#16171B",
            "card": "#1E2026",
            "panel": "#0A0A0A",
            "sidebar": "#080808"
        },
        "border": {
            "default": "#2A2B30",
            "subtle": "#2f2f2f",
            "accent": "#00FF8840"
        },
        "text": {
            "primary": "#FFFFFF",
            "secondary": "#F4F4F5",
            "muted": "#71717A",
            "disabled": "#6A6A6A"
        },
        "brand": {
            "primary": "#00FF88",
            "secondary": "#22C55E",
            "warning": "#FF8800",
            "danger": "#FF4444"
        }
    },
    "typography": {
        "fonts": {
            "mono": [
                "JetBrains Mono",
                "Roboto Mono",
                "Space Mono"
            ],
            "sans": [
                "Space Grotesk",
                "Inter"
            ]
        },
        "styles": {
            "display": {
                "fontFamily": "sans",
                "fontSize": "48px",
                "fontWeight": 700,
                "letterSpacing": "-1px"
            },
            "h1": {
                "fontFamily": "sans",
                "fontSize": "36px",
                "fontWeight": 700,
                "letterSpacing": "-1px"
            },
            "h2": {
                "fontFamily": "sans",
                "fontSize": "18px",
                "fontWeight": 600
            },
            "metricValue": {
                "fontFamily": "sans",
                "fontSize": "32px",
                "fontWeight": 700,
                "letterSpacing": "-1px"
            },
            "metricValueLarge": {
                "fontFamily": "mono",
                "fontSize": "40px",
                "fontWeight": 700
            },
            "label": {
                "fontFamily": "mono",
                "fontSize": "10px",
                "fontWeight": 600,
                "letterSpacing": "0.5px",
                "textTransform": "uppercase"
            },
            "commentLabel": {
                "fontFamily": "mono",
                "fontSize": "11px",
                "fontWeight": 600,
                "textTransform": "uppercase"
            },
            "body": {
                "fontFamily": "sans",
                "fontSize": "12px",
                "fontWeight": 400
            },
            "bodyMono": {
                "fontFamily": "mono",
                "fontSize": "11px",
                "fontWeight": 400
            }
        }
    },
    "layout": {
        "radius": {
            "none": "0px",
            "sm": "2px",
            "md": "4px",
            "lg": "12px",
            "full": "100px"
        },
        "borderWidth": {
            "default": "1px",
            "thick": "2px"
        },
        "spacing": {
            "xs": "4px",
            "sm": "8px",
            "md": "12px",
            "lg": "16px",
            "xl": "24px",
            "2xl": "32px",
            "3xl": "40px"
        }
    },
    "components": {
        "card": {
            "background": "$colors.background.card",
            "border": "1px solid $colors.border.default",
            "radius": "$layout.radius.md",
            "padding": "$layout.spacing.xl"
        },
        "sidebar": {
            "background": "$colors.background.sidebar",
            "borderRight": "1px solid $colors.border.subtle",
            "padding": "$layout.spacing.xl"
        },
        "metricsCard": {
            "background": "$colors.background.panel",
            "border": "1px solid $colors.border.subtle",
            "radius": "$layout.radius.none",
            "padding": "$layout.spacing.xl"
        },
        "badges": {
            "active": {
                "color": "$colors.brand.primary",
                "background": "transparent",
                "border": "1px solid $colors.border.accent"
            },
            "solid": {
                "color": "$colors.background.app",
                "background": "$colors.brand.primary",
                "border": "none"
            }
        },
        "navigation": {
            "active": {
                "color": "$colors.text.primary",
                "iconColor": "$colors.brand.primary",
                "background": "rgba(0, 255, 136, 0.06)",
                "borderLeft": "2px solid $colors.brand.primary"
            },
            "inactive": {
                "color": "$colors.text.disabled",
                "iconColor": "$colors.text.disabled",
                "background": "transparent",
                "borderLeft": "2px solid transparent"
            }
        }
    },
    "designSystemPatterns": {
        "textConventions": "Use uppercase for labels, nav items, and table headers. Prefix section labels with '// ' (e.g. '// SYSTEM STATUS', '// TODAY_METRICS') or use SCREAMING_SNAKE_CASE for metric labels (e.g. 'TOTAL_REVENUE'). Add '::' or '>' for technical separators.",
        "visualHierarchy": "High contrast between bright green primary accents (#00FF88) against deep black/dark gray backgrounds. Borders are thin (1px), rigid, and structural.",
        "icons": "Lucide icons, typically sized 12px to 16px to match mono font sizing. Stroke width should be 1.5 to 2px."
    }
}
