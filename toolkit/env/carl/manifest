# CARL Manifest
# ==============
# Controls which domains are active and how they're triggered.
#
# Format:
#   DEVMODE=true|false                (debug output in responses)
#   {DOMAIN}_STATE=active|inactive    (whether domain is enabled)
#   {DOMAIN}_ALWAYS_ON=true|false     (load every prompt, no keyword matching)
#   {DOMAIN}_RECALL=keyword1,keyword2 (triggers on-demand loading)
#   {DOMAIN}_EXCLUDE=word1,word2      (skip domain if these words in prompt)
#
# Loading Logic:
#   1. ALWAYS_ON=true domains load every prompt
#   2. Other active domains load when recall keywords match user prompt
#   3. Exclusions are checked before matching

# ============================================================================
# SETTINGS
# ============================================================================
DEVMODE=false

# ============================================================================
# GLOBAL - Universal rules (always loaded)
# ============================================================================
GLOBAL_STATE=active
GLOBAL_ALWAYS_ON=true

# ============================================================================
# CONTEXT - Dynamic bracket rules based on context window usage
# ============================================================================
CONTEXT_STATE=active
CONTEXT_ALWAYS_ON=true

# ============================================================================
# COMMANDS - Star-commands like *dev, *review, *brief
# Detected via *pattern matching, rules in commands file
# ============================================================================
COMMANDS_STATE=active

# ============================================================================
# ROUTING - Model selection guidance for Task/agent spawning
# ============================================================================
ROUTING_STATE=active
ROUTING_ALWAYS_ON=false
ROUTING_RECALL=model,agent,task,spawn,haiku,sonnet,opus,routing

# ============================================================================
# EXECUTION - Build-phase workflow routing after planning
# ============================================================================
EXECUTION_STATE=active
EXECUTION_ALWAYS_ON=false
EXECUTION_RECALL=implement,build,execute,coding,start building,build-stack,verify,review,quality check,review-stack,ready to ship,closeout,close out,wrap up,end of session,end of day,pivot context,resume prompt

# ============================================================================
# OPUS-4-7 - Behavior policy for Claude Opus 4.7 (released 2026-04-16)
# Source of truth: ~/.claude/references/opus-4-7-operating-notes.md
# ============================================================================
OPUS-4-7_STATE=active
OPUS-4-7_ALWAYS_ON=true
